# ─────────────────────────────────────────────────────────────
# Snagd marketing site — environment variables
# Copy to .env.local for local dev. On Cloudflare Pages, set these
# in the Pages project → Settings → Environment variables.
# Only NEXT_PUBLIC_* values are exposed to the browser. This is a
# static marketing site, so everything here is public by design.
# ─────────────────────────────────────────────────────────────

# App store download links (use real URLs once the app is published).
# Until then these point to "coming soon" / waitlist and the buttons
# fall back to a placeholder state.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# Where the "Get Snagd" CTA sends people before the app is live
# (e.g. a waitlist / email capture). Optional.
NEXT_PUBLIC_WAITLIST_URL=

# Creator / affiliate program signup link (Phase 4 — billing provider).
NEXT_PUBLIC_CREATOR_SIGNUP_URL=

# Support contact shown in footer + support page.
NEXT_PUBLIC_SUPPORT_EMAIL=support@snagd.app

# Analytics (optional, add later). Left blank in V1.
NEXT_PUBLIC_ANALYTICS_ID=
