# Public API origin used by the bundled iOS app. Leave blank for same-origin web requests.
NEXT_PUBLIC_API_BASE_URL=

# App store links become active after each release is approved.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# Optional public marketing links.
NEXT_PUBLIC_WAITLIST_URL=
NEXT_PUBLIC_CREATOR_SIGNUP_URL=

# Public support contact.
NEXT_PUBLIC_SUPPORT_EMAIL=support@snagd.app

# Optional analytics identifier. Keep blank until privacy disclosures are updated.
NEXT_PUBLIC_ANALYTICS_ID=
